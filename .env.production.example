# ============================================
# 生产环境配置 - 请复制此文件为 .env
# ============================================

# 管理员密码（请修改为强密码）
ADMIN_PASSWORD=your_strong_admin_password_here

# 应用端口（容器内部端口，主机端口在 docker-compose.yml 配置）
PORT=3000

# ============================================
# MySQL 数据库配置
# ============================================
# 注意：DB_HOST 必须是 "mysql"（Docker 服务名），不要用 localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
# 请修改为强密码（至少 12 位，包含大小写字母、数字、特殊字符）
DB_PASSWORD=your_strong_mysql_password_here
DB_NAME=blog_db

# 运行环境
NODE_ENV=production
